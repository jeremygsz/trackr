generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
}

model InviteCode {
  id        String    @id @default(uuid())
  code      String    @unique
  createdBy String
  usedBy    String?
  usedAt    DateTime?
  expiresAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  creator   User      @relation("CreatedInvites", fields: [createdBy], references: [id])
  user      User?     @relation("UsedInvites", fields: [usedBy], references: [id])

  @@index([createdBy])
  @@index([usedBy])
}

model User {
  id                  String         @id @default(uuid())
  firstname           String
  lastname            String
  email               String         @unique
  password            String
  role                Role           @default(user)
  currency            String         @default("EUR")
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt
  onboardingCompleted Boolean        @default(false)
  banks               Bank[]
  categories          Category[]
  incomes             Income[]
  installments        Installment[]
  createdInvites      InviteCode[]   @relation("CreatedInvites")
  usedInvite          InviteCode[]   @relation("UsedInvites")
  spendings           Spending[]
  stores              Store[]
  subcategories       Subcategory[]
  subscriptions       Subscription[]
  tags                Tag[]
  userBanks           UserBank[]
}

model Bank {
  id            String         @id @default(uuid())
  label         String         @unique
  logo          String?
  color         String?
  userId        String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  user          User?          @relation(fields: [userId], references: [id])
  incomes       Income[]
  installments  Installment[]
  spendingLines SpendingLine[]
  subscriptions Subscription[]
  userBanks     UserBank[]

  @@index([userId])
}

model UserBank {
  id        String   @id @default(uuid())
  userId    String
  bankId    String
  selected  Boolean  @default(false)
  listOrder Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  bank      Bank     @relation(fields: [bankId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, bankId])
  @@index([userId])
}

model Income {
  id            String      @id @default(uuid())
  userId        String
  label         String
  amount        Decimal     @db.Decimal(10, 2)
  currency      String      @default("EUR")
  date          DateTime
  recurrency    Recurrency?
  subcategoryId String
  bankId        String
  notes         String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  bank          Bank        @relation(fields: [bankId], references: [id])
  subcategory   Subcategory @relation(fields: [subcategoryId], references: [id])
  user          User        @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([subcategoryId])
  @@index([bankId])
}

model Category {
  id            String        @id @default(uuid())
  label         String        @unique
  icon          String?
  color         String?
  createdBy     String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  user          User?         @relation(fields: [createdBy], references: [id])
  subcategories Subcategory[]

  @@index([createdBy])
}

model Subcategory {
  id            String         @id @default(uuid())
  label         String
  icon          String?
  color         String?
  categoryId    String
  createdBy     String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  incomes       Income[]
  installments  Installment[]
  spendings     Spending[]
  category      Category       @relation(fields: [categoryId], references: [id])
  user          User?          @relation(fields: [createdBy], references: [id])
  subscriptions Subscription[]

  @@unique([label, categoryId])
  @@index([categoryId])
  @@index([createdBy])
}

model Store {
  id            String         @id @default(uuid())
  label         String         @unique
  logo          String?
  website       String?
  userId        String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  installments  Installment[]
  spendings     Spending[]
  user          User?          @relation(fields: [userId], references: [id])
  subscriptions Subscription[]

  @@index([userId])
}

model Tag {
  id            String            @id @default(uuid())
  label         String
  color         String
  userId        String
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  installments  InstallmentTag[]
  spendings     SpendingTag[]
  subscriptions SubscriptionTag[]
  user          User              @relation(fields: [userId], references: [id])

  @@unique([label, userId])
  @@index([userId])
}

model Spending {
  id            String         @id @default(uuid())
  userId        String
  label         String
  subcategoryId String
  storeId       String?
  currency      String         @default("EUR")
  spendingDate  DateTime
  notes         String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  store         Store?         @relation(fields: [storeId], references: [id])
  subcategory   Subcategory    @relation(fields: [subcategoryId], references: [id])
  user          User           @relation(fields: [userId], references: [id])
  lines         SpendingLine[]
  tags          SpendingTag[]

  @@index([userId])
  @@index([subcategoryId])
  @@index([storeId])
}

model SpendingLine {
  id          String   @id @default(uuid())
  spendingId  String
  label       String?
  amountGross Decimal  @db.Decimal(10, 2)
  discount    Decimal  @default(0) @db.Decimal(10, 2)
  amountNet   Decimal  @db.Decimal(10, 2)
  bankId      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  bank        Bank     @relation(fields: [bankId], references: [id])
  spending    Spending @relation(fields: [spendingId], references: [id], onDelete: Cascade)

  @@index([spendingId])
  @@index([bankId])
}

model SpendingTag {
  spendingId String
  tagId      String
  spending   Spending @relation(fields: [spendingId], references: [id], onDelete: Cascade)
  tag        Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([spendingId, tagId])
  @@index([tagId])
}

model Installment {
  id                  String            @id @default(uuid())
  userId              String
  label               String
  subcategoryId       String
  storeId             String?
  bankId              String
  currency            String            @default("EUR")
  totalAmount         Decimal           @db.Decimal(10, 2)
  occurrences         Int
  amountPerOccurrence Decimal           @db.Decimal(10, 2)
  startAt             DateTime
  endAt               DateTime
  notes               String?
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
  bank                Bank              @relation(fields: [bankId], references: [id])
  store               Store?            @relation(fields: [storeId], references: [id])
  subcategory         Subcategory       @relation(fields: [subcategoryId], references: [id])
  user                User              @relation(fields: [userId], references: [id])
  lines               InstallmentLine[]
  tags                InstallmentTag[]

  @@index([userId])
  @@index([subcategoryId])
  @@index([storeId])
  @@index([bankId])
}

model InstallmentLine {
  id            String      @id @default(uuid())
  installmentId String
  dueDate       DateTime
  amount        Decimal     @db.Decimal(10, 2)
  isPaid        Boolean     @default(false)
  paidAt        DateTime?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  installment   Installment @relation(fields: [installmentId], references: [id], onDelete: Cascade)

  @@index([installmentId])
}

model InstallmentTag {
  installmentId String
  tagId         String
  installment   Installment @relation(fields: [installmentId], references: [id], onDelete: Cascade)
  tag           Tag         @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([installmentId, tagId])
  @@index([tagId])
}

model Subscription {
  id            String            @id @default(uuid())
  userId        String
  label         String
  subcategoryId String
  storeId       String?
  bankId        String
  amount        Decimal           @db.Decimal(10, 2)
  currency      String            @default("EUR")
  recurrency    Recurrency        @default(monthly)
  startAt       DateTime
  endAt         DateTime?
  nextBillingAt DateTime
  isActive      Boolean           @default(true)
  notes         String?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  bank          Bank              @relation(fields: [bankId], references: [id])
  store         Store?            @relation(fields: [storeId], references: [id])
  subcategory   Subcategory       @relation(fields: [subcategoryId], references: [id])
  user              User              @relation(fields: [userId], references: [id])
  tags          SubscriptionTag[]

  @@index([userId])
  @@index([subcategoryId])
  @@index([storeId])
  @@index([bankId])
}

model SubscriptionTag {
  subscriptionId String
  tagId          String
  subscription   Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  tag          Tag          @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([subscriptionId, tagId])
  @@index([tagId])
}

enum Role {
  admin
  user
}

enum Recurrency {
  weekly
  monthly
  yearly
}
